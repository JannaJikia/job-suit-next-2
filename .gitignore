# Next.js
/.next/
/out/
/build

# Dependencies
/node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing
/coverage

# Production
/dist

# Env — never commit secrets (keep `.env.example` tracked)
.env*
!.env.example

# Debug / tooling logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# TypeScript / ESLint cache
*.tsbuildinfo
.eslintcache

# Turborepo (if you add it later)
.turbo

# Vercel
.vercel

# OS
.DS_Store
Thumbs.db

# Certificates / keys
*.pem

# IDEs (local settings; commit team rules elsewhere if you want)
.vscode/
.idea/

# Claude Code — local permissions / machine-specific
.claude/

# Optional local scratch (e.g. temp dev logs)
.next-dev-run.log
.next-dev-run.pid
